diff --git a/main/audio/wake_words/custom_wake_word.cc b/main/audio/wake_words/custom_wake_word.cc
index 982bbe9..98ed2c9 100644
--- a/main/audio/wake_words/custom_wake_word.cc
+++ b/main/audio/wake_words/custom_wake_word.cc
@@ -91,7 +91,24 @@ bool CustomWakeWord::Initialize(AudioCodec* codec, srmodel_list_t* models_list)
         models_ = esp_srmodel_init("model");
 #ifdef CONFIG_CUSTOM_WAKE_WORD
         threshold_ = CONFIG_CUSTOM_WAKE_WORD_THRESHOLD / 100.0f;
-        commands_.push_back({CONFIG_CUSTOM_WAKE_WORD, CONFIG_CUSTOM_WAKE_WORD_DISPLAY, "wake"});
+        // stackchan-embodied patch: 支持分号分隔的多个唤醒词 (显示名取自 DISPLAY 同位置分段, 缺省用第一个)
+        {
+            std::string words = CONFIG_CUSTOM_WAKE_WORD;
+            std::string displays = CONFIG_CUSTOM_WAKE_WORD_DISPLAY;
+            auto split = [](const std::string& s) {
+                std::vector<std::string> out; size_t start = 0, pos;
+                while ((pos = s.find(';', start)) != std::string::npos) {
+                    if (pos > start) out.push_back(s.substr(start, pos - start));
+                    start = pos + 1;
+                }
+                if (start < s.size()) out.push_back(s.substr(start));
+                return out;
+            };
+            auto w = split(words); auto d = split(displays);
+            for (size_t i = 0; i < w.size(); i++) {
+                commands_.push_back({w[i], i < d.size() ? d[i] : d.empty() ? w[i] : d[0], "wake"});
+            }
+        }
 #endif
     } else {
         models_ = models_list;
