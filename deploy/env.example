# 复制为 ../.env-stack 并填入真实值 (gitignored)。deploy.sh 会读它注入各服务。

# OpenClaw 大脑 gateway (OpenAI 兼容端点) — 狗蛋 agent 所在
OPENCLAW_URL=http://127.0.0.1:18789/v1/chat/completions   # 与大脑同机时用 loopback
OPENCLAW_TOKEN=your-openclaw-gateway-token
OPENCLAW_MODEL=openclaw/xiaogoudan                        # 你给机器人建的 agent

# 辅脑 LiteLLM → Bedrock (视觉/记忆总结/兜底)
LITELLM_MASTER_KEY=sk-generate-a-random-one
BEDROCK_REGION=us-west-2
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-6          # agent 出错时的兜底对话模型

# body 端点鉴权 (让能力槽位/大脑主动借嘴说话)
BODY_TOKEN=generate-a-random-one

# CloudFront↔ALB 校验头 (公网入口防绕过)
ORIGIN_VERIFY=generate-a-random-one

# 设备下发的 wss/OTA 地址 (你的 CloudFront 域名)
PUBLIC_DOMAIN=your-distribution.cloudfront.net

# TTS 音色 (edge-tts)
TTS_VOICE=zh-CN-YunxiaNeural

# 异步总线: agent 超过这么多秒没答完就先"应一声", 干完主动播报
INLINE_WAIT=8
